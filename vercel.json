{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "env": {
    "NODE_ENV": "production",
    "DISABLE_DB_WRITE": "true"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/src/server.js"
    },
    {
      "source": "/:path*",
      "destination": "/public/:path*"
    }
  ]
}
